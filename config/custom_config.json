{
  "fields": [
    { "path": "candidate_name", "from": "full_name", "type": "string", "required": true },
    { "path": "primary_email", "from": "emails[0]", "type": "string", "required": true },
    { "path": "primary_phone", "from": "phones[0]", "type": "string", "normalize": "E164" },
    { "path": "skills_list", "from": "skills[].name", "type": "string[]", "normalize": "canonical" },
    { "path": "country_code", "from": "location.country", "type": "string", "normalize": "canonical" }
  ],
  "include_confidence": true,
  "include_provenance": false,
  "on_missing": "omit"
}
